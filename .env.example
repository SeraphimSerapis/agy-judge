# Copy this file to .env in the workspace where you run agy-judge.
# Do not commit .env. It may contain provider credentials.
#
# Real secrets are best kept in your shell environment (e.g. ~/.zshenv)
# so the working tree never contains credentials. The CLI prefers real
# env vars over .env over .agy-judge.json. See src/config.ts for the
# precedence rules.

JUDGE_BASE_URL=http://localhost:8000/v1
JUDGE_MODEL=your-judge-model
JUDGE_API_KEY=
JUDGE_HEADERS='{}'
JUDGE_MODE=advisory
JUDGE_PROFILE=default
JUDGE_FAIL_OPEN=true
JUDGE_TIMEOUT_MS=60000

# Truncation limits (bytes). Hook payloads larger than maxPayloadBytes
# are serialized and sliced to avoid dominating the review context.
# JUDGE_MAX_DIFF_BYTES=120000
# JUDGE_MAX_OUTPUT_BYTES=60000
# JUDGE_MAX_PAYLOAD_BYTES=120000

# Custom headers example:
# JUDGE_HEADERS='{"X-API-KEY":"your-provider-key"}'

# Optional blocking severities for block mode:
# JUDGE_BLOCK_ON=critical,high

# Profile:
# JUDGE_PROFILE=security
# JUDGE_PROFILE=tests
# JUDGE_PROFILE=docs
# JUDGE_PROFILE=release

# Hook dedup (Stop hook only):
# JUDGE_HOOK_DEDUP=true
# 0 means skip the same hook review key until the git state changes.
# JUDGE_HOOK_COOLDOWN_MS=0
# JUDGE_HOOK_STATE_FILE=/tmp/agy-judge-hook-state.json
# JUDGE_HOOK_LOG_FILE=/tmp/agy-judge-hook-events.ndjson

# Process lockfile (shared by review and hook):
# JUDGE_LOCK_FILE=/tmp/agy-judge.lock

# Verdict file (read by statusline / external tooling):
# JUDGE_VERDICT_FILE=/tmp/agy-judge-verdict.json

# Save hook stdin to a file (redacted by default):
# JUDGE_DUMP_PAYLOAD=./captured-payload.json
# JUDGE_DUMP_RAW=false


# Auto-fix on WARN/FAIL instead of asking the user (Stop hook only):
# JUDGE_HOOK_AUTOFIX=true
