# Copy this file to .env in the workspace where you run agy-judge.
# Do not commit .env. It may contain provider credentials.

JUDGE_BASE_URL=http://localhost:8000/v1
JUDGE_MODEL=your-judge-model
JUDGE_API_KEY=
JUDGE_HEADERS='{}'
JUDGE_MODE=advisory
JUDGE_PROFILE=default
JUDGE_FAIL_OPEN=true
JUDGE_TIMEOUT_MS=60000

# Optional examples:
# JUDGE_HEADERS='{"X-API-KEY":"your-provider-key"}'
# JUDGE_BLOCK_ON=critical,high
# JUDGE_MAX_DIFF_BYTES=120000
# JUDGE_PROFILE=security
